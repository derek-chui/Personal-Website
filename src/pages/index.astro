<script>
    (window as any).switchGallery = (tab: string, btn: HTMLButtonElement) => {
        document.querySelectorAll<HTMLElement>('.gallery-panel').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll<HTMLButtonElement>('.gallery-tab-btn').forEach(b => b.classList.remove('active'));
        const panel = document.getElementById('gallery-' + tab);
        if (panel) panel.classList.remove('hidden');
        btn.classList.add('active');
    };

    document.addEventListener('DOMContentLoaded', () => {
        const sections = document.querySelectorAll('section');
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });
        
        sections.forEach(section => {
            observer.observe(section);
        });

        const lightbox = document.getElementById('lightbox') as HTMLDivElement | null;
        const lbImg = lightbox?.querySelector('.lightbox-img') as HTMLImageElement | null;
        const lbCaption = lightbox?.querySelector('.lightbox-caption') as HTMLElement | null;

        let activeHref: string | null = null;
        let armNavigateAt = 0;

        const openLightbox = (imgEl: HTMLImageElement) => {
        if (!lightbox || !lbImg || !lbCaption) return;

        lbImg.src = imgEl.src;
        lbImg.alt = imgEl.alt || '';
        lbCaption.textContent =
            imgEl.dataset.caption ||
            (imgEl.closest('.gallery-item')?.querySelector('.gallery-caption') as HTMLElement | null)?.textContent ||
            '';

        activeHref = imgEl.dataset.link || null;
        armNavigateAt = Date.now() + 400;

        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        };

        const closeLightbox = () => {
        if (!lightbox || !lbImg) return;

        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';

        activeHref = null;

        setTimeout(() => { lbImg.src = ''; }, 150);
        };

        document
        .querySelectorAll<HTMLImageElement>('.gallery-item img, .gallery-media img, .featured-app-image img, .sample-img')
        .forEach((img) => img.addEventListener('click', () => openLightbox(img)));

        lbImg?.addEventListener('click', (e) => {
        if (!lightbox?.classList.contains('open')) return;
        if (!activeHref) return;
        if (Date.now() < armNavigateAt) return;

        e.preventDefault();
        e.stopPropagation();
        const w = window.open(activeHref, '_blank', 'noopener,noreferrer');
        if (w) w.opener = null;
        });

        lightbox?.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        if (target.matches('[data-lightbox-close]')) {
            e.preventDefault();
            e.stopPropagation();
            closeLightbox();
        }
        });

        document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && lightbox?.classList.contains('open')) closeLightbox();
        });



    });

    // const heroText = document.querySelector('.hero h1');
    // const originalText = heroText.textContent;
    // heroText.textContent = '';

    // let i = 0;
    // const typeWriter = setInterval(() => {
    //     if (i < originalText.length) {
    //         heroText.textContent += originalText.charAt(i);
    //         i++;
    //     } else {
    //         clearInterval(typeWriter);
    //     }
    // }, 80);
</script>

